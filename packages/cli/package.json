{
  "name": "tsoap-cli",
  "version": "0.0.1",
  "description": "End-to-end type-safe SOAP client for TypeScript. Generate typed RPC wrappers directly from WSDLs.",
  "keywords": ["soap", "typescript", "wsdl", "rpc", "trpc", "types", "client", "node-soap", "generator"],
  "type": "module",
  "bin": {
    "tsoap": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "soap": "^1.1.6",
    "typescript": "^5.9.2"
  },
  "devDependencies": {
    "@types/node": "^18.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Deodat-Lawson/tsoap.git",
    "directory": "packages/cli"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  }
}
